{
  "name": "vue-starter-template",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check build-only",
    "preview": "vite preview",
    "test:unit": "vitest",
    "build-only": "cross-env NODE_OPTIONS=--max-old-space-size=8192 vite-ssg build",
    "type-check": "vue-tsc --build",
    "lint": "eslint . --fix",
    "orval": "orval",
    "analyze": "cross-env ANALYZE=true pnpm build",
    "postinstall": "npx simple-git-hooks",
    "pre-commit": "npx lint-staged && npm run type-check"
  },
  "dependencies": {
    "@jsquash/avif": "^2.1.1",
    "@jsquash/jpeg": "^1.6.0",
    "@jsquash/oxipng": "^2.3.0",
    "@jsquash/resize": "^2.1.1",
    "@jsquash/webp": "^1.5.0",
    "@tanstack/vue-query": "^5.92.9",
    "@unocss/reset": "^66.6.0",
    "@vueuse/components": "^14.2.1",
    "@vueuse/core": "^14.2.1",
    "axios": "^1.13.5",
    "comlink": "^4.4.2",
    "dayjs": "^1.11.19",
    "elheif": "^0.1.0",
    "esbuild-wasm": "^0.27.3",
    "exceljs": "^4.4.0",
    "fabric": "7.2.0",
    "highlight.js": "^11.11.1",
    "js-md5": "^0.8.3",
    "jszip": "^3.10.1",
    "localforage": "^1.10.0",
    "lodash-es": "^4.17.23",
    "loglevel": "^1.9.2",
    "lucide-vue-next": "^0.575.0",
    "marked": "^17.0.4",
    "marked-highlight": "^2.2.4",
    "mermaid": "^11.14.0",
    "monaco-editor": "^0.55.1",
    "motion-v": "^1.10.3",
    "papaparse": "^5.5.3",
    "pdfjs-dist": "^5.5.207",
    "pinia": "^3.0.4",
    "qs": "^6.15.0",
    "reflect-metadata": "^0.2.2",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5",
    "vue": "^3.5.29",
    "vue-advanced-cropper": "^2.8.9",
    "vue-json-pretty": "^2.6.0",
    "vue-router": "^5.0.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.5.0",
    "@iconify-json/carbon": "^1.2.18",
    "@tsconfig/node22": "^22.0.5",
    "@types/jsdom": "^28.0.0",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.3.0",
    "@types/papaparse": "^5.5.2",
    "@types/prismjs": "^1.26.6",
    "@types/qs": "^6.14.0",
    "@unhead/vue": "^2.1.4",
    "@unocss/eslint-plugin": "^66.6.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitejs/plugin-vue-jsx": "^5.1.4",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "code-inspector-plugin": "^1.4.2",
    "cross-env": "^10.1.0",
    "eslint": "^10",
    "eslint-plugin-format": "^2.0.0",
    "jsdom": "^28.1.0",
    "lightningcss": "^1.32.0",
    "lint-staged": "^16.2.7",
    "npm-run-all2": "^8.0.4",
    "orval": "^8.4.2",
    "prism-themes": "^1.9.0",
    "prismjs": "^1.30.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass-embedded": "^1.97.3",
    "simple-git-hooks": "^2.13.1",
    "typescript": "~5.9.3",
    "unocss": "^66.6.0",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^31.0.0",
    "unplugin-vue-router": "^0.19.2",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-vue-layouts": "^0.11.0",
    "vite-plugin-wasm": "^3.5.0",
    "vite-ssg": "^28.3.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "simple-git-hooks"
    ],
    "ignoredBuiltDependencies": [
      "esbuild",
      "vue-demi"
    ]
  },
  "simple-git-hooks": {
    "pre-commit": "npm run pre-commit"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
